{
  "name": "achuk-lang",
  "displayName": "Achuk Language",
  "description": "Syntax highlighting, snippets, and language configuration for Achuk — the AI-first programming language. Works in VS Code, Cursor, Windsurf, and VSCodium.",
  "version": "0.1.0",
  "publisher": "lambdaq-labs",
  "license": "UPL-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LambdaQ-Labs/achuk",
    "directory": "editors/vscode"
  },
  "homepage": "https://achuk.dev",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "achuk",
    "achuk",
    "ai",
    "agents",
    "functional"
  ],
  "contributes": {
    "languages": [
      {
        "id": "achuk",
        "aliases": [
          "Achuk",
          "achuk"
        ],
        "extensions": [
          ".achuk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "achuk",
        "scopeName": "source.achuk",
        "path": "./syntaxes/achuk.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "achuk",
        "path": "./snippets/achuk.json"
      }
    ]
  }
}
