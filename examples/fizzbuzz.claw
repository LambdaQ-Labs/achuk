# FizzBuzz — functions, if/else, and the modulo operator.
# Run: claw run fizzbuzz.claw
fizz : U64 -> Str
fizz = |n| {
    if n % 3 == 0 and n % 5 == 0 "FizzBuzz"
    else if n % 3 == 0 "Fizz"
    else if n % 5 == 0 "Buzz"
    else n.to_str()
}

main! = |_args| {
    echo!(fizz(3))
    echo!(fizz(5))
    echo!(fizz(15))
    echo!(fizz(7))
    Ok({})
}
